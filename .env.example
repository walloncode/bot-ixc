# Copie para .env e preencha. Nunca commitar .env real.

# --- IXC ---
IXC_BASE_URL=https://SEU-IXC.com.br
IXC_USER=
IXC_PASSWORD=

# --- Navegador ---
HEADLESS=false

# --- IA (só exceções) ---
AI_PROVIDER=anthropic        # anthropic | openai | none
AI_API_KEY=
AI_MODEL=claude-opus-4-8
CONFIDENCE_THRESHOLD=85

# --- OCR ---
# Caminho do executável do Tesseract (Windows). Ex: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=

# --- Banco / Logs ---
DB_URL=sqlite:///./logs/agent.db
RULES_FILE=regras.md
LOG_DIR=logs
